# ─────────────────────────────────────────────────────────
#  DATABASE  (Neon PostgreSQL — get a free DB at neon.tech)
# ─────────────────────────────────────────────────────────
# Pooled connection URL (used by Prisma at runtime)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true&connection_limit=1"
# Direct (non-pooled) URL — required by Prisma migrations
DATABASE_DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─────────────────────────────────────────────────────────
#  NEXTAUTH
# ─────────────────────────────────────────────────────────
# Your production domain e.g. https://myapp.vercel.app
NEXTAUTH_URL="https://your-app.vercel.app"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-long-random-secret"

# ─────────────────────────────────────────────────────────
#  APP
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ─────────────────────────────────────────────────────────
#  STRIPE
# ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_xxx"
STRIPE_MONTHLY_PRICE_ID="price_xxx"
STRIPE_ONE_TIME_PRICE_ID="price_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# ─────────────────────────────────────────────────────────
#  CLOUDFLARE TURNSTILE  (optional — comment out to disable)
# ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x..."
# TURNSTILE_SECRET_KEY="0x..."
